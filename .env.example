# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
ADMIN_EMAILS=admin1@yourdomain.com,admin2@yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
WEBHOOK_SHARED_SECRET=change-this-secret
PAYMENT_RATE_LIMIT_PER_MIN=30
WEBHOOK_RATE_LIMIT_PER_MIN=120

# ─── Admin Security ──────────────────────────────────────────
# Secret token for admin route obfuscation (e.g. "x7k9p2m" → route becomes /panel-x7k9p2m)
VITE_ADMIN_ROUTE_TOKEN=
ADMIN_ROUTE_TOKEN=

# TOTP / MFA – 32-byte key in hex (64 chars). Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENCRYPTION_KEY=

# IP whitelist for admin panel (comma-separated, leave empty to allow all)
ADMIN_ALLOWED_IPS=

# Geo-blocking: ISO 3166-1 alpha-2 country codes to block (e.g. CN,RU,KP,IR)
BLOCKED_COUNTRIES=

# Max failed admin access attempts before 24h block (default: 3)
ADMIN_MAX_ATTEMPTS=3

# Anti-scraping: max requests per IP per minute before 1h block (default: 60)
SCRAPING_MAX_PER_MIN=60

# Payment Gateways (configure the ones you use)
PUSHINPAY_API_TOKEN=
BLACKOUT_PUBLIC_KEY=
BLACKOUT_SECRET_KEY=
NOVAPLEX_API_KEY=
NOVAPLEX_API_SECRET=

# OAuth (optional)
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=

# FTP Deploy (optional, for ftp_deploy.js)
FTP_HOST=
FTP_PORT=21
FTP_USER=
FTP_PASSWORD=
